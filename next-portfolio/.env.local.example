# GitHub Raw File URL for portfolio data
# Replace with your actual GitHub raw URL:
# https://raw.githubusercontent.com/YOUR_USERNAME/YOUR_REPO/main/data.json
NEXT_PUBLIC_DATA_URL=https://raw.githubusercontent.com/YOUR_USERNAME/YOUR_REPO/main/data.json

# Gmail SMTP for contact form (Nodemailer)
# Use any Gmail account to SEND emails — messages will always arrive at mashookhkhan7862@gmail.com
# GMAIL_USER = the Gmail address you use to send (can be any Gmail you own)
# GMAIL_APP_PASSWORD = 16-character App Password (NOT your normal Gmail password)
# To generate: Google Account → Security → 2-Step Verification → App Passwords
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
